from models.CarnetEntrainement import CarnetEntrainement
from stats.stats import (
    volume_total_par_groupe_musculaire,
    nb_series_par_groupe_et_par_muscle_cible_par_semaine,
    lister_exercices_differents_par_groupe,
    frequence_groupe_et_par_muscle_par_semaine,
    un_rm_estime_par_exercice,
    comparaison_nb_series_par_groupe_et_fourchette_scientifique,
    evolution_des_charges_dans_le_temps,
)

carnet = CarnetEntrainement.charger("carnet.json")

print("=" * 60)
print("STAT 1 - Volume total par groupe musculaire (poids × reps cumulé)")
print("=" * 60)
for groupe, volume in sorted(volume_total_par_groupe_musculaire(carnet).items()):
    print(f"  {groupe:15s} : {volume:.1f}")

print("\n" + "=" * 60)
print("STAT 2 - Nombre de séries par groupe et par muscle (par semaine)")
print("=" * 60)
series_groupe, series_muscle = nb_series_par_groupe_et_par_muscle_cible_par_semaine(carnet)
print("\n  Par groupe musculaire :")
for cle, nb in sorted(series_groupe.items()):
    annee, sem, groupe = cle
    print(f"    Semaine {sem}/{annee} - {groupe:15s} : {nb} séries")
print("\n  Par muscle ciblé :")
for cle, nb in sorted(series_muscle.items()):
    annee, sem, muscle = cle
    print(f"    Semaine {sem}/{annee} - {muscle:35s} : {nb} séries")

print("\n" + "=" * 60)
print("STAT 3 - Exercices différents pratiqués par groupe")
print("=" * 60)
for groupe, liste in sorted(lister_exercices_differents_par_groupe(carnet).items()):
    print(f"\n  {groupe} :")
    for nom in liste:
        print(f"    - {nom}")

print("\n" + "=" * 60)
print("STAT 4 - Fréquence par semaine (nb séances par groupe/muscle)")
print("=" * 60)
freq_groupe, freq_muscle = frequence_groupe_et_par_muscle_par_semaine(carnet)
print("\n  Par groupe musculaire :")
for cle, nb in sorted(freq_groupe.items()):
    annee, sem, groupe = cle
    print(f"    Semaine {sem}/{annee} - {groupe:15s} : {nb} séance(s)")
print("\n  Par muscle ciblé :")
for cle, nb in sorted(freq_muscle.items()):
    annee, sem, muscle = cle
    print(f"    Semaine {sem}/{annee} - {muscle:35s} : {nb} séance(s)")

print("\n" + "=" * 60)
print("STAT 5 - 1RM estimé par exercice (Epley)")
print("=" * 60)
for nom, rm in sorted(un_rm_estime_par_exercice(carnet).items()):
    print(f"  {nom:45s} : {rm:.1f}")

print("\n" + "=" * 60)
print("STAT 6 - Comparaison vs fourchettes scientifiques")
print("=" * 60)
for cle, infos in sorted(comparaison_nb_series_par_groupe_et_fourchette_scientifique(carnet).items()):
    annee, sem, groupe = cle
    print(f"  Semaine {sem}/{annee} - {groupe:15s} : {infos['nb_series']:3} séries → {infos['statut']}")

print("\n" + "=" * 60)
print("STAT 7 - Évolution des charges par exercice")
print("=" * 60)
for nom, liste in sorted(evolution_des_charges_dans_le_temps(carnet).items()):
    print(f"\n  {nom} :")
    for date, charge in liste:
        print(f"    {date} : {charge:.1f}")